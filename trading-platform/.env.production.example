APP_NAME="AI Algorithmic Trading Platform"
ENVIRONMENT=production
LOG_LEVEL=INFO

DATABASE_URL=sqlite:///./trading_platform.db
REDIS_URL=redis://127.0.0.1:6379/0

NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000

SIMULATION_ONLY=true
DEMO_EXECUTION=true
LIVE_EXECUTION_ENABLED=false
BROKER_EXECUTION_ENABLED=false

# LIVE_EXECUTION_ENABLED must remain false unless manually approved in a future production-go-live phase.
# BROKER_EXECUTION_ENABLED must remain false unless manually approved in a future production-go-live phase.

# MetaTrader 5 demo credentials. Keep real secrets out of source control.
MT5_LOGIN=
MT5_SERVER=
MT5_PASSWORD=
